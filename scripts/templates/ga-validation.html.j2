<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GA Readiness — {{ target }}</title>
    <style>
        :root {
            --bg-primary: #0f172a;
            --bg-card: #1e293b;
            --bg-inner: #182235;
            --bg-code: #0f172a;
            --border: #334155;
            --border-hover: #475569;
            --text-primary: #f8fafc;
            --text-secondary: #e2e8f0;
            --text-muted: #94a3b8;
            --text-mono: #cbd5e1;
            --accent: #3b82f6;
            --green: #34d399; --green-bg: #065f46; --green-border: #059669;
            --yellow: #fbbf24; --yellow-bg: #78350f; --yellow-border: #d97706;
            --red: #f87171; --red-bg: #7f1d1d; --red-border: #dc2626;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif; line-height: 1.6; max-width: 1200px; margin: 0 auto; padding: 20px; background: var(--bg-primary); color: var(--text-primary); }
        .container { background: var(--bg-card); padding: 32px; border-radius: 12px; box-shadow: 0 10px 25px -5px rgba(0,0,0,.3); border: 1px solid var(--border); }

        /* ── Header ── */
        .report-header { margin-bottom: 28px; }
        .report-header h1 { font-size: 1.6em; font-weight: 700; margin-bottom: 4px; }
        .report-header .subtitle { color: var(--text-muted); font-size: .92em; }
        h2 { color: var(--text-secondary); margin: 28px 0 14px; font-size: 1.15em; font-weight: 600; border-bottom: 2px solid var(--border); padding-bottom: 8px; }

        /* ── Info Grid ── */
        .info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 1px;
            background: var(--border);
            border: 1px solid var(--border);
            border-radius: 8px;
            overflow: hidden;
            margin-bottom: 24px;
        }
        .info-cell { background: var(--bg-inner); padding: 16px 20px; }
        .info-label { font-size: .72em; color: var(--text-muted); text-transform: uppercase; letter-spacing: .07em; margin-bottom: 4px; }
        .info-value { font-size: 1.05em; font-weight: 600; color: var(--text-secondary); }

        /* ── Badges ── */
        .badge { display: inline-block; padding: 4px 10px; border-radius: 9999px; font-size: .78em; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; }
        .badge-pass { background: var(--green-bg); color: var(--green); border: 1px solid var(--green-border); }
        .badge-warn { background: var(--yellow-bg); color: var(--yellow); border: 1px solid var(--yellow-border); }
        .badge-fail { background: var(--red-bg); color: var(--red); border: 1px solid var(--red-border); }
        .badge-lg { padding: 6px 14px; font-size: .82em; }

        /* ── Stats ── */
        .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 12px; margin-bottom: 28px; }
        .stat { text-align: center; padding: 14px; border-radius: 8px; border: 1px solid var(--border); background: var(--bg-inner); }
        .stat-num { font-size: 1.8em; font-weight: 800; line-height: 1.2; }
        .stat-lbl { font-size: .76em; color: var(--text-muted); text-transform: uppercase; letter-spacing: .05em; }

        /* ── Summary Table ── */
        .summary-tbl { width: 100%; border-collapse: collapse; margin-bottom: 28px; font-size: .9em; }
        .summary-tbl th { text-align: left; padding: 10px 14px; color: var(--text-muted); border-bottom: 2px solid var(--border); font-weight: 600; font-size: .8em; text-transform: uppercase; letter-spacing: .04em; }
        .summary-tbl td { padding: 10px 14px; border-bottom: 1px solid #1e293b; }
        .summary-tbl tr:hover { background: rgba(51,65,85,.25); }
        .chk-num { display: inline-flex; align-items: center; justify-content: center; width: 26px; height: 26px; border-radius: 50%; font-size: .8em; font-weight: 700; }
        .chk-pass { background: var(--green-bg); color: var(--green); border: 1px solid var(--green-border); }
        .chk-warn { background: var(--yellow-bg); color: var(--yellow); border: 1px solid var(--yellow-border); }
        .chk-fail { background: var(--red-bg); color: var(--red); border: 1px solid var(--red-border); }

        /* ── Detail Sections ── */
        .section { background: var(--bg-inner); border: 1px solid var(--border); border-radius: 8px; margin-bottom: 14px; overflow: hidden; transition: border-color .2s; }
        .section:hover { border-color: var(--border-hover); }
        .section-hdr { display: flex; justify-content: space-between; align-items: center; padding: 14px 20px; cursor: pointer; user-select: none; }
        .section-hdr:hover { background: rgba(51,65,85,.15); }
        .section-title { display: flex; align-items: center; gap: 12px; }
        .section-name { font-weight: 600; font-size: 1.02em; color: var(--text-secondary); }
        .section-body { padding: 0 20px 18px; border-top: 1px solid var(--border); }
        .msg-block { background: var(--bg-code); border: 1px solid #1e293b; border-radius: 6px; padding: 14px; font-family: 'Consolas','Courier New',monospace; font-size: .86em; color: var(--text-mono); white-space: pre-wrap; word-break: break-word; margin-top: 12px; }

        /* ── Inner Tables ── */
        .tbl { width: 100%; border-collapse: collapse; font-size: .88em; margin-top: 12px; }
        .tbl th { text-align: left; padding: 8px 12px; color: var(--text-muted); border-bottom: 2px solid var(--border); font-weight: 600; font-size: .8em; text-transform: uppercase; }
        .tbl td { padding: 8px 12px; border-bottom: 1px solid #1e293b; color: var(--text-mono); }
        .tbl td:first-child { font-weight: 600; color: var(--text-secondary); }
        .ok { color: var(--green); } .no { color: var(--red); } .wr { color: var(--yellow); }

        /* ── CI Timeline ── */
        .ci-row { display: flex; gap: 8px; margin-top: 12px; flex-wrap: wrap; }
        .ci-card { display: flex; flex-direction: column; align-items: center; padding: 10px 14px; border-radius: 8px; border: 1px solid var(--border); background: var(--bg-code); min-width: 115px; font-size: .82em; text-decoration: none; color: inherit; transition: border-color .2s; }
        .ci-card:hover { border-color: var(--accent); }
        .ci-dot { width: 12px; height: 12px; border-radius: 50%; margin-bottom: 6px; }
        .ci-dot-pass { background: var(--green); } .ci-dot-fail { background: var(--red); } .ci-dot-warn { background: var(--yellow); }

        /* ── Upgrade Path Pills ── */
        .path-list { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 10px; }
        .path-pill { background: var(--bg-code); border: 1px solid var(--border); padding: 4px 10px; border-radius: 6px; font-family: monospace; font-size: .85em; color: var(--text-mono); }
        .path-arrow { color: var(--accent); margin: 0 2px; }

        /* ── Misc ── */
        a { color: var(--accent); text-decoration: none; } a:hover { text-decoration: underline; }
        .warn-box { border-left: 3px solid var(--yellow); margin-top: 12px; }
        .sub-label { color: var(--text-muted); font-size: .82em; margin: 14px 0 6px; text-transform: uppercase; letter-spacing: .04em; }
        .footer { margin-top: 36px; padding-top: 14px; border-top: 1px solid var(--border); text-align: center; color: #64748b; font-size: .8em; }
    </style>
</head>
<body>
<div class="container">

    <!-- ═══════════ HEADER ═══════════ -->
    <div class="report-header">
        <h1>ROSA GA Readiness Validation Report</h1>
        <p class="subtitle">Production readiness checklist for OpenShift {{ target }}</p>
    </div>

    <!-- ═══════════ INFO GRID ═══════════ -->
    <div class="info-grid">
        <div class="info-cell">
            <div class="info-label">Target Version</div>
            <div class="info-value">{{ target }}</div>
        </div>
        {% if baseline %}
        <div class="info-cell">
            <div class="info-label">Baseline Version</div>
            <div class="info-value">{{ baseline }}</div>
        </div>
        {% endif %}
        <div class="info-cell">
            <div class="info-label">OCM Environment</div>
            <div class="info-value" style="text-transform:uppercase;">{{ env }}</div>
        </div>
        <div class="info-cell">
            <div class="info-label">Overall Result</div>
            <div class="info-value">
                {% if validation_result == 'PASS' %}<span class="badge badge-pass badge-lg">PASS</span>{% else %}<span class="badge badge-fail badge-lg">FAIL</span>{% endif %}
            </div>
        </div>
        <div class="info-cell">
            <div class="info-label">Validated At</div>
            <div class="info-value">{{ timestamp }}</div>
        </div>
    </div>

    <!-- ═══════════ STATS ═══════════ -->
    <div class="stats">
        <div class="stat"><div class="stat-num" style="color:var(--accent);">{{ metrics.total }}</div><div class="stat-lbl">Total Checks</div></div>
        <div class="stat"><div class="stat-num" style="color:var(--green);">{{ metrics.passed if metrics.passed is defined else metrics.total - metrics.failures - metrics.warnings }}</div><div class="stat-lbl">Passed</div></div>
        <div class="stat"><div class="stat-num" style="color:var(--yellow);">{{ metrics.warnings }}</div><div class="stat-lbl">Warnings</div></div>
        <div class="stat"><div class="stat-num" style="color:var(--red);">{{ metrics.critical_failures }}</div><div class="stat-lbl">Critical Failures</div></div>
    </div>

    <!-- ═══════════ SUMMARY TABLE ═══════════ -->
    <h2>Validation Summary</h2>
    <table class="summary-tbl">
        <thead><tr><th style="width:40px;">#</th><th>Check</th><th style="width:90px;text-align:center;">Status</th></tr></thead>
        <tbody>
        {% set ns = namespace(idx=1) %}
        {% for check_name, check_data in results.items() %}
        <tr>
            <td><span class="chk-num chk-{{ 'pass' if check_data.status == 'PASS' else 'warn' if check_data.status == 'WARN' else 'fail' }}">{{ ns.idx }}</span></td>
            <td><a href="#chk-{{ ns.idx }}">{{ check_name }}</a></td>
            <td style="text-align:center;"><span class="badge badge-{{ 'pass' if check_data.status == 'PASS' else 'warn' if check_data.status == 'WARN' else 'fail' }}">{{ check_data.status }}</span></td>
        </tr>
        {% set ns.idx = ns.idx + 1 %}
        {% endfor %}
        </tbody>
    </table>

    <!-- ═══════════ CHECK DETAILS ═══════════ -->
    <h2>Check Details</h2>

    {% set ns = namespace(idx=1) %}
    {% for check_name, check_data in results.items() %}
    <div class="section" id="chk-{{ ns.idx }}">
        <div class="section-hdr" onclick="var b=this.nextElementSibling;b.style.display=b.style.display==='none'?'block':'none'">
            <div class="section-title">
                <span class="chk-num chk-{{ 'pass' if check_data.status == 'PASS' else 'warn' if check_data.status == 'WARN' else 'fail' }}">{{ ns.idx }}</span>
                <span class="section-name">{{ check_name }}</span>
            </div>
            <span class="badge badge-{{ 'pass' if check_data.status == 'PASS' else 'warn' if check_data.status == 'WARN' else 'fail' }}">{{ check_data.status }}</span>
        </div>
        <div class="section-body">

        {# ─── AWS Marketplace ─── #}
        {% if check_data.channels is defined and check_data.channels and check_data.channels.values()|first is mapping and 'rosa_classic' in check_data.channels.values()|first %}
        <table class="tbl">
            <thead><tr><th>Channel</th><th style="text-align:center;">ROSA Classic</th><th style="text-align:center;">ROSA HCP</th><th>Version Detected</th></tr></thead>
            <tbody>
            {% for chan, info in check_data.channels.items() %}
            <tr>
                <td>{{ chan }}</td>
                <td style="text-align:center;">{% if info.rosa_classic %}<span class="ok">&#10003;</span>{% else %}<span class="no">&#10007;</span>{% endif %}</td>
                <td style="text-align:center;">{% if info.rosa_hcp %}<span class="ok">&#10003;</span>{% else %}<span class="no">&#10007;</span>{% endif %}</td>
                <td style="font-family:monospace;font-size:.9em;">{{ info.rosa_classic_output or info.rosa_hcp_output or '—' }}</td>
            </tr>
            {% endfor %}
            </tbody>
        </table>

        {# ─── GCP Marketplace ─── #}
        {% elif check_data.channels is defined and check_data.channels and check_data.channels.values()|first is mapping and 'gcp_marketplace' in check_data.channels.values()|first %}
        <table class="tbl">
            <thead><tr><th>Channel</th><th style="text-align:center;">GCP Marketplace</th><th>Version Detected</th></tr></thead>
            <tbody>
            {% for chan, info in check_data.channels.items() %}
            <tr>
                <td>{{ chan }}</td>
                <td style="text-align:center;">{% if info.gcp_marketplace %}<span class="ok">&#10003;</span>{% else %}<span class="no">&#10007;</span>{% endif %}</td>
                <td style="font-family:monospace;font-size:.9em;">{{ info.gcp_marketplace_output or '—' }}</td>
            </tr>
            {% endfor %}
            </tbody>
        </table>

        {# ─── Version Gates ─── #}
        {% elif check_data.gates is defined and check_data.gates %}
        <table class="tbl">
            <thead><tr><th>Gate Label</th><th style="text-align:center;">STS Only</th><th>Description</th><th>Docs</th></tr></thead>
            <tbody>
            {% for g in check_data.gates %}
            <tr>
                <td style="font-family:monospace;font-size:.88em;">{{ g.label }}</td>
                <td style="text-align:center;">{% if g.sts_only %}<span class="wr">Yes</span>{% else %}No{% endif %}</td>
                <td style="font-size:.86em;">{{ g.description[:150] }}</td>
                <td>{% if g.documentation_url %}<a href="{{ g.documentation_url }}" target="_blank">View</a>{% else %}—{% endif %}</td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
        {% if check_data.gates[0].warning_message is defined and check_data.gates[0].warning_message %}
        <div class="msg-block warn-box">{{ check_data.gates[0].warning_message }}</div>
        {% endif %}

        {# ─── Upgrade Paths ─── #}
        {% elif check_data.upgrade is defined and check_data.upgrade %}
        {% set up = check_data.upgrade %}
        <table class="tbl">
            <thead><tr><th>Metric</th><th>Value</th></tr></thead>
            <tbody>
                <tr><td>Baseline</td><td style="font-family:monospace;">{{ up.baseline }}</td></tr>
                <tr><td>Target</td><td style="font-family:monospace;">{{ up.target }}</td></tr>
                <tr><td>Comparison Type</td><td>{{ 'Z-Stream' if up.is_z_stream else 'Cross-Minor' }}</td></tr>
                <tr><td>Channel Queried</td><td style="font-family:monospace;">{{ up.channel_queried }}</td></tr>
                <tr><td>Total Paths</td><td>{{ up.total_paths }}</td></tr>
                <tr><td>Paths from {{ up.baseline }}</td><td>{{ up.paths_from_baseline }}</td></tr>
                <tr><td>Paths to {{ up.target }}</td><td>{{ up.paths_to_target }}</td></tr>
                <tr><td>Direct Path ({{ up.baseline }} &rarr; {{ up.target }})</td><td>{% if up.direct_path_exists %}<span class="ok">Yes</span>{% else %}<span class="wr">No</span>{% endif %}</td></tr>
            </tbody>
        </table>
        {% if up.sample_paths %}
        <p class="sub-label">Sample Upgrade Paths</p>
        <div class="path-list">
            {% for p in up.sample_paths %}<span class="path-pill">{{ p.from }} <span class="path-arrow">&rarr;</span> {{ p.to }}</span>{% endfor %}
        </div>
        {% endif %}

        {# ─── CI Job Status ─── #}
        {% elif check_data.ci is defined and check_data.ci %}
        {% set ci = check_data.ci %}
        <p style="color:var(--text-muted);font-size:.84em;margin:10px 0 4px;">
            Job: <a href="{{ ci.history_url }}" target="_blank" style="font-family:monospace;font-size:.95em;">{{ ci.job_name }}</a>
        </p>
        <div class="ci-row">
            {% for run in ci.runs %}
            <a class="ci-card" href="{{ run.url }}" target="_blank" title="Build #{{ run.id }}">
                <span class="ci-dot ci-dot-{{ 'pass' if run.status == 'PASS' else 'fail' if run.status == 'FAIL' else 'warn' }}"></span>
                <span style="font-weight:600;">{{ run.status }}</span>
                <span style="color:var(--text-muted);font-size:.88em;">{{ run.started[:10] if run.started|length > 10 else run.started }}</span>
            </a>
            {% endfor %}
        </div>

        {# ─── Default: raw message ─── #}
        {% else %}
        <div class="msg-block">{{ check_data.message }}</div>
        {% endif %}

        </div>
    </div>
    {% set ns.idx = ns.idx + 1 %}
    {% endfor %}

    <div class="footer">Generated by ROSA Gap Analysis &mdash; GA Readiness Validation Suite</div>
</div>
</body>
</html>
