<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GA Readiness Validation Report</title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            line-height: 1.6;
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
            background-color: #0f172a;
            color: #f8fafc;
        }
        .container {
            background-color: #1e293b;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.3), 0 8px 10px -6px rgba(0, 0, 0, 0.3);
            border: 1px solid #334155;
        }
        h1 {
            color: #f8fafc;
            border-bottom: 3px solid #3b82f6;
            padding-bottom: 12px;
            margin-top: 0;
            font-weight: 700;
        }
        h2 {
            color: #e2e8f0;
            margin-top: 30px;
            border-bottom: 2px solid #334155;
            padding-bottom: 8px;
            font-weight: 600;
        }
        .metadata-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            background-color: #182235;
            padding: 20px;
            border-radius: 8px;
            margin: 20px 0;
            border: 1px solid #334155;
        }
        .metadata-item {
            display: flex;
            flex-direction: column;
        }
        .metadata-label {
            font-size: 0.85em;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 4px;
        }
        .metadata-value {
            font-size: 1.1em;
            font-weight: 600;
            color: #f1f5f9;
        }
        .status-badge {
            display: inline-block;
            padding: 6px 12px;
            border-radius: 9999px;
            font-size: 0.85em;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        .status-badge.pass {
            background-color: #065f46;
            color: #34d399;
            border: 1px solid #059669;
        }
        .status-badge.warn {
            background-color: #78350f;
            color: #fbbf24;
            border: 1px solid #d97706;
        }
        .status-badge.fail {
            background-color: #7f1d1d;
            color: #fca5a5;
            border: 1px solid #dc2626;
        }
        .summary-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 15px;
            margin: 20px 0;
        }
        .card {
            padding: 15px 20px;
            border-radius: 8px;
            text-align: center;
            border: 1px solid #334155;
        }
        .card.total {
            background-color: #1e293b;
        }
        .card.passed {
            background-color: rgba(6, 95, 70, 0.2);
            border-color: rgba(5, 150, 105, 0.4);
        }
        .card.warnings {
            background-color: rgba(120, 53, 15, 0.2);
            border-color: rgba(217, 119, 6, 0.4);
        }
        .card.failures {
            background-color: rgba(127, 29, 29, 0.2);
            border-color: rgba(220, 38, 38, 0.4);
        }
        .card-val {
            font-size: 2em;
            font-weight: 800;
            margin-top: 5px;
        }
        .card-label {
            font-size: 0.85em;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        .checklist {
            display: flex;
            flex-direction: column;
            gap: 15px;
            margin-top: 25px;
        }
        .check-item {
            background-color: #182235;
            border: 1px solid #334155;
            border-radius: 8px;
            padding: 20px;
            transition: all 0.2s ease;
        }
        .check-item:hover {
            border-color: #475569;
            background-color: #1e293b;
        }
        .check-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }
        .check-title-group {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .check-id {
            font-family: monospace;
            background-color: #334155;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 0.9em;
            font-weight: 700;
            color: #cbd5e1;
        }
        .check-title {
            font-size: 1.15em;
            font-weight: 600;
            color: #f1f5f9;
        }
        .check-body {
            background-color: #0f172a;
            border: 1px solid #1e293b;
            border-radius: 6px;
            padding: 15px;
            margin-top: 10px;
        }
        .check-msg {
            font-family: 'Consolas', 'Courier New', monospace;
            font-size: 0.95em;
            color: #cbd5e1;
            white-space: pre-wrap;
            margin: 0;
        }
        .footer {
            margin-top: 45px;
            padding-top: 20px;
            border-top: 1px solid #334155;
            text-align: center;
            color: #64748b;
            font-size: 0.85em;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>ROSA GA Readiness Validation Report</h1>
        
        <div class="metadata-grid">
            <div class="metadata-item">
                <span class="metadata-label">Validation Target</span>
                <span class="metadata-value">{{ target }}</span>
            </div>
            <div class="metadata-item">
                <span class="metadata-label">OCM Environment</span>
                <span class="metadata-value" style="text-transform: uppercase;">{{ env }}</span>
            </div>
            <div class="metadata-item">
                <span class="metadata-label">Overall Status</span>
                <span class="metadata-value">
                    {% if validation_result == 'PASS' %}
                        <span class="status-badge pass">PASS</span>
                    {% else %}
                        <span class="status-badge fail">FAIL</span>
                    {% endif %}
                </span>
            </div>
            <div class="metadata-item">
                <span class="metadata-label">Validated At</span>
                <span class="metadata-value">{{ timestamp }}</span>
            </div>
        </div>

        <div class="summary-cards">
            <div class="card total">
                <div class="card-label">Total Checks</div>
                <div class="card-val" style="color: #60a5fa;">{{ metrics.total }}</div>
            </div>
            <div class="card passed">
                <div class="card-label">Passed</div>
                <div class="card-val" style="color: #34d399;">{{ metrics.total - metrics.failures - metrics.warnings }}</div>
            </div>
            <div class="card warnings">
                <div class="card-label">Warnings</div>
                <div class="card-val" style="color: #fbbf24;">{{ metrics.warnings }}</div>
            </div>
            <div class="card failures">
                <div class="card-label">Critical Failures</div>
                <div class="card-val" style="color: #f87171;">{{ metrics.critical_failures }}</div>
            </div>
        </div>

        <h2>Checklist Details</h2>
        <div class="checklist">
            {% for check_id, check_data in results | dictsort %}
                <div class="check-item">
                    <div class="check-header">
                        <div class="check-title-group">
                            <span class="check-id">{{ check_id }}</span>
                            <span class="check-title">{{ check_data.name }}</span>
                        </div>
                        <div>
                            {% if check_data.status == 'PASS' %}
                                <span class="status-badge pass">PASS</span>
                            {% elif check_data.status == 'WARN' %}
                                <span class="status-badge warn">WARN</span>
                            {% else %}
                                <span class="status-badge fail">FAIL</span>
                            {% endif %}
                        </div>
                    </div>
                    <div class="check-body">
                        <pre class="check-msg">{{ check_data.message }}</pre>
                    </div>
                </div>
            {% endfor %}
        </div>

        <div class="footer">
            <p>Generated by ROSA Gap Analysis Tooling &bull; Antigravity AI Team &bull; Red Hat OpenShift Service on AWS</p>
        </div>
    </div>
</body>
</html>
